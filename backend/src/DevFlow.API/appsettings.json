{
  "ConnectionStrings": {
  "DefaultConnection": "Server=localhost,1433;Database=DevFlowDb;User Id=sa;Password=DevFlow@12345;TrustServerCertificate=True;"
},

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "DevFlow.API"
    }
  },

  "AllowedHosts": "*"
}
